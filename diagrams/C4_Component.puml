' Minimal PlantUML compatibility layer for the FitLife diagrams.
' It keeps the existing diagram files working without pulling the full C4 library.

!unquoted procedure Person($alias, $label, $descr="")
actor "$label" as $alias
!endprocedure

!unquoted procedure System($alias, $label, $descr="")
rectangle "$label" as $alias
!endprocedure

!unquoted procedure System_Ext($alias, $label, $descr="")
rectangle "$label" as $alias
!endprocedure

!unquoted procedure Container_Boundary($alias, $label, $descr="")
rectangle "$label" as $alias
!endprocedure

!unquoted procedure Container($alias, $label, $techn="", $descr="")
rectangle "$label" as $alias
!endprocedure

!unquoted procedure Component($alias, $label, $descr="")
rectangle "$label" as $alias
!endprocedure

!unquoted procedure Rel($from, $to, $label="")
$from --> $to : $label
!endprocedure
