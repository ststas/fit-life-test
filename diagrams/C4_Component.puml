' Minimal compatibility layer for the FitLife diagrams.
' Kept tiny on purpose so it works with the PlantUML version in GitHub Actions.

!define Person($alias, $label, $descr="") actor "$label" as $alias
!define System($alias, $label, $descr="") rectangle "$label" as $alias
!define System_Ext($alias, $label, $descr="") rectangle "$label" as $alias
!define Container_Boundary($alias, $label, $descr="") package "$label" as $alias
!define Container($alias, $label, $techn="", $descr="") package "$label" as $alias
!define Component($alias, $label, $descr="") component "$label" as $alias
!define Rel($from, $to, $label="") $from --> $to : $label
